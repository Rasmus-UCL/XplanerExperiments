      <LineId Id="462" Count="0" />
      <LineId Id="365" Count="0" />
      <LineId Id="466" Count="1" />
      <LineId Id="465" Count="0" />
      <LineId Id="366" Count="40" />
      <LineId Id="178" Count="0" />
    </LineIds>
    <LineIds Name="MAIN.EnterMovementArea">
      <LineId Id="2" Count="2" />
      <LineId Id="6" Count="2" />
      <LineId Id="1" Count="0" />
    </LineIds>
    <LineIds Name="MAIN.Initialization">
      <LineId Id="2" Count="5" />
