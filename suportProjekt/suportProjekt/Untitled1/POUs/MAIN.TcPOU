      <LineId Id="10" Count="0" />
      <LineId Id="8" Count="1" />
      <LineId Id="1" Count="0" />
    </LineIds>
    <LineIds Name="MAIN.LeavingMovementArea">
      <LineId Id="2" Count="2" />
      <LineId Id="6" Count="2" />
      <LineId Id="1" Count="0" />
    </LineIds>
    <LineIds Name="MAIN.MoverDetectionInfos">
      <LineId Id="1" Count="1" />
    </LineIds>
